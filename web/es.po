#: src/components/core/DownloadLogsFeedback.tsx:34
#, javascript-format
msgid ""
"The file %s contains a record of the installer activity so far, useful to "
"diagnose installation issues."
msgstr ""
"El archivo %s contiene un registro de la actividad del instalador hasta el "
